#!/usr/bin/env bash
# Place in a directory on PATH which precedes REAL_CLAUDE on PATH so that typing
# `claude` runs this instead of the real binary. We call the real binary by
# absolute path to avoid recursing into this shim.

REAL_CLAUDE=""
self="$(readlink -f "${BASH_SOURCE[0]}")"
while IFS= read -r candidate; do
  [[ "$(readlink -f "$candidate")" == "$self" ]] && continue
  REAL_CLAUDE="$candidate"
  break
done < <(type -ap claude)

if [[ -z "$REAL_CLAUDE" ]]; then
  echo "claude shim: no real claude binary found on PATH" >&2
  exit 127
fi

# One flag (stripped before exec on real binary):
#   --shim   apply the shim: inject the env vars + default model, 
#            but let the user's own --model override the shim's 
#            (the shim only fills in --model when the user omitted it).
#
# Examples:
#   claude -p "hi"                       # default: real binary bare
#   claude --shim -p "hi"                # inject env + default model gpt-5.6-sol
#   claude --shim --model foo -p "hi"    # inject env + keep user's --model foo
shim=0
args=()
for arg in "$@"; do
  case "$arg" in
    --shim)  shim=1 ;;
    *) args+=("$arg") ;;
  esac
done

# By default the shim bypasses the injected env vars and default model — runs the real 
# binary bare, with the user's args (including any --model) passed through verbatim.
if (( ! shim )); then
  exec "$REAL_CLAUDE" "${args[@]}"
fi

# From here on the shim injects its env vars + default model.
#
# subagent_model tracks the *effective* --model so CLAUDE_CODE_SUBAGENT_MODEL can
# follow it. It defaults to the shim's model and is overridden below when the user
# supplies their own --model.
subagent_model=gpt-5.6-sol

# --shim: keep the user's flags; only inject the shim default for --model when the
# user did NOT supply it, so the user's own value overrides the shim's.
have_model=0
want_model_val=0
for arg in "${args[@]}"; do
  if (( want_model_val )); then subagent_model="$arg"; want_model_val=0; fi
  case "$arg" in
    --model)                 have_model=1; want_model_val=1 ;;
    --model=*)               have_model=1; subagent_model="${arg#--model=}" ;;
  esac
done
inject=()
(( have_model )) || inject+=(--model gpt-5.6-sol)

exec env \
  CLAUDE_CODE_SUBAGENT_MODEL="$subagent_model" \
  CLAUDE_CODE_ALWAYS_ENABLE_EFFORT=1 \
  CLAUDE_CODE_MAX_TOOL_USE_CONCURRENCY=3 \
  ENABLE_TOOL_SEARCH=false \
  ANTHROPIC_BASE_URL="http://127.0.0.1:8317" \
  ANTHROPIC_AUTH_TOKEN="cli-proxy-local" \
  "$REAL_CLAUDE" "${inject[@]}" "${args[@]}"
